{
  "_comment": "Dense 3D sphere RVE rendered as static SVG (orthographic axonometric).",

  "domain_box": [1.0, 1.0, 1.0],
  "seed": 17,

  "distributions": {
    "uniform_x":      { "type": "uniform_real", "a": 0.10, "b": 0.90 },
    "uniform_y":      { "type": "uniform_real", "a": 0.10, "b": 0.90 },
    "uniform_z":      { "type": "uniform_real", "a": 0.10, "b": 0.90 },
    "uniform_radius": { "type": "uniform_real", "a": 0.06, "b": 0.10 }
  },

  "shapes": [
    { "type": "sphere_input",
      "pos_x_dist":  "uniform_x",
      "pos_y_dist":  "uniform_y",
      "pos_z_dist":  "uniform_z",
      "radius_dist": "uniform_radius" }
  ],

  "generator":   { "type": "only_inside",     "max_attempts": 500000 },
  "termination": { "type": "volume_fraction", "target_fraction": 0.10 },

  "postprocess": [
    { "type": "svg_3d", "canvas_width": 900.0,
      "output_path": "dense_spheres_svg3d.svg" }
  ]
}
