{
  "_comment": "Mixed 3D RVE — spheres + boxes in a unit cube, 15% volume fraction.",

  "domain_box": [1.0, 1.0, 1.0],
  "seed": 5,

  "distributions": {
    "uniform_x":      { "type": "uniform_real", "a": 0.10, "b": 0.90 },
    "uniform_y":      { "type": "uniform_real", "a": 0.10, "b": 0.90 },
    "uniform_z":      { "type": "uniform_real", "a": 0.10, "b": 0.90 },
    "sphere_r":       { "type": "uniform_real", "a": 0.05, "b": 0.09 },
    "box_w":          { "type": "uniform_real", "a": 0.10, "b": 0.16 },
    "box_h":          { "type": "uniform_real", "a": 0.08, "b": 0.14 },
    "box_d":          { "type": "uniform_real", "a": 0.07, "b": 0.12 }
  },

  "shapes": [
    { "type": "sphere_input",
      "pos_x_dist":  "uniform_x", "pos_y_dist":  "uniform_y",
      "pos_z_dist":  "uniform_z", "radius_dist": "sphere_r" },
    { "type": "box_input",
      "pos_x_dist": "uniform_x", "pos_y_dist": "uniform_y",
      "pos_z_dist": "uniform_z",
      "width_dist": "box_w", "height_dist": "box_h", "depth_dist": "box_d" }
  ],

  "generator":   { "type": "only_inside",     "max_attempts": 500000 },
  "termination": { "type": "volume_fraction", "target_fraction": 0.15 },

  "postprocess": [
    { "type": "three_js",
      "output_path": "mixed_3d.html" }
  ]
}
