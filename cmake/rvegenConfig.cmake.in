@PACKAGE_INIT@

# rvegen package config — consumed by find_package(rvegen).
#
# The four upstream dependencies must be discoverable by the consumer's
# CMake. Boost / Eigen3 / nlohmann_json have standard CMake configs;
# numsim-core ships its own config alongside its install (sibling of
# rvegen in the numsim-stack family).

include(CMakeFindDependencyMacro)
find_dependency(Boost)
find_dependency(Eigen3)
find_dependency(nlohmann_json)
find_dependency(numsim-core)

if(NOT TARGET rvegen::rvegen_lib)
    include("${CMAKE_CURRENT_LIST_DIR}/rvegenTargets.cmake")
endif()

check_required_components(rvegen)
